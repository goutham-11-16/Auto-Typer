<Window x:Class="AutoTyper.Views.AccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoTyper.Views"
        xmlns:vm="clr-namespace:AutoTyper.ViewModels"
        mc:Ignorable="d"
        Title="Access Control" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#1E1E1E"
        Foreground="White">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="AUTO TYPER ACCESS CONTROL" 
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Foreground="#888"/>

        <!-- Main Content Area -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <!-- Status Text -->
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="24" FontWeight="SemiBold" 
                       HorizontalAlignment="Center"
                       Foreground="{Binding StatusColor}"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,20"/>
            
            <!-- Device ID Display -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                <TextBlock Text="Device ID: " Foreground="#AAA"/>
                <TextBlock Text="{Binding DeviceId}" Foreground="White" FontFamily="Consolas"/>
            </StackPanel>

            <!-- Loading Spinner (Simple Text for now) -->
            <TextBlock Text="Please wait..." 
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                       HorizontalAlignment="Center" Foreground="#AAA"/>

            <!-- Update Required UI -->
            <StackPanel Visibility="{Binding IsUpdateRequired, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding UpdateMessage}" Foreground="#FF6666" Margin="0,0,0,10" TextAlignment="Center"/>
                <Button Content="Update Now" Command="{Binding OpenUpdateUrlCommand}" 
                        Padding="20,10" Background="#FF4444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
            
            <!-- Request Access Form -->
            <StackPanel Visibility="{Binding IsRequestFormVisible, Converter={StaticResource BoolToVis}}" Width="300">
                <TextBlock Text="Enter your username to request access:" Margin="0,0,0,5" Foreground="#CCC"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="5" Margin="0,0,0,10" Background="#333" Foreground="White" BorderThickness="0"/>
                <Button Content="Submit Request" Command="{Binding RequestAccessCommand}" 
                        Padding="10" Background="#4444FF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <!-- Pending UI -->
            <StackPanel Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Your request has been submitted and is awaiting administrator approval." 
                           TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center" Foreground="#FFAA00"/>
                <TextBlock Text="Please restart the application later to check status." 
                           TextAlignment="Center" Margin="0,10,0,0" Foreground="#888"/>
            </StackPanel>
            
            <!-- Access Denied UI -->
            <StackPanel Visibility="{Binding IsAccessDenied, Converter={StaticResource BoolToVis}}">
                 <TextBlock Text="This device has been explicitly banned or access revoked." 
                            TextAlignment="Center" Foreground="#FF4444"/>
                 <TextBlock Text="Contact administrator for assistance." 
                            TextAlignment="Center" Margin="0,5,0,0" Foreground="#888"/>
            </StackPanel>

        </StackPanel>

        <!-- Footer -->
        <Button Grid.Row="2" Content="Exit" Command="{Binding ExitCommand}" 
                HorizontalAlignment="Right"
                Padding="15,5" Background="#333" Foreground="#CCC" BorderThickness="0" Cursor="Hand" Click="ExitButton_Click"/>
    </Grid>
</Window>
